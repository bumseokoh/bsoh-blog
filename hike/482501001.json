at":37.684952,"lng":127.00869,"alt":562,"signposts":[]},{"name":"우이봉(우이암)","desc":"우이암은 관음보살이 부처님을 향해 기도하는 형상이고, 호랑이, 코끼리, 두꺼비등 모든 짐승들의 형상이 관음봉을 향해 머리를 조아리고 있어 관음봉 또는 사모봉으로 불리웠지만, 언제부터인가 소귀를 닮았다고 우이암으로 불리워진다.","lat":37.684956,"lng":127.008751,"alt":562,"signposts":[]},{"name":"미륵봉","desc":"미륵봉 아래에 은석암이라는 암자 이름을 따서 은석봉으로 불리워졌다가 미륵부처를 닮아서 미륵봉이라 함","lat":37.700176,"lng":127.026802,"alt":474,"signposts":[]},{"name":"미륵봉","desc":"오래 전부터 은석봉 또는 미륵바위로 불리워져왔다","lat":37.700172,"lng":127.026817,"alt":475,"signposts":[]},{"name":"Y계곡 정상","desc":"Y형의 계곡의 상단","lat":37.700317,"lng":127.015587,"alt":730,"signposts":[]},{"name":"신선대 정상","desc":"자운봉대신 신선대가 정상역할","lat":37.69865,"lng":127.01503,"alt":754,"signposts":[]},{"name":"신선대","desc":"도봉산최고봉은 자운봉이나 오를수없어신선대에정상석마련","lat":37.698643,"lng":127.015053,"alt":738,"signposts":[]},{"name":"상상봉","desc":"사패산 1보루","lat":37.724407,"lng":127.025841,"alt":374,"signposts":[]},{"name":"포대산불감시초소","desc":"포대능선이란 능선 중간에 대공포진지인 포대가 있었다하여 붙여진 이름이다.","lat":37.708126,"lng":127.019539,"alt":671,"signposts":[]},{"name":"656봉","desc":"칼바위 구간에 위치","lat":37.694641,"lng":127.008881,"alt":661,"signposts":[]},{"name":"사패산 정상","desc":"넓은 바위. 도봉산 전체를 조망할 수 있음.","lat":37.722359,"lng":127.010445,"alt":569,"signposts":[]}]},"peak":[37.698647,127.015007]}